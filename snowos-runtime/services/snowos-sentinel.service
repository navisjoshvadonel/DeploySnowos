[Unit]
Description=SnowOS AI Sentinel Daemon
Documentation=https://github.com/snowos/core
After=snowos-broker.service
Requires=snowos-broker.service

[Service]
Type=simple
User=snowos-sys
Group=snowos-sys
ExecStart=/usr/bin/python3 /opt/snowos/system_services/ai_sentinel/sentinel_daemon.py
Restart=always
RestartSec=3

# Sandboxing
ProtectSystem=strict
ProtectHome=read-only
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
